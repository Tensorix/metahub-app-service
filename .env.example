# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=metahub
POSTGRES_PASSWORD=metahub_password
POSTGRES_DB=metahub
POSTGRES_PORT=5432

# ============================================
# Redis 配置
# ============================================
REDIS_PORT=6379

# ============================================
# 应用配置
# ============================================
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
ALLOWED_HOSTS=*

# 是否在启动时运行数据库迁移
RUN_MIGRATIONS=true

# ============================================
# 前端运行时配置
# ============================================
# 后端 API 地址（前端会使用此配置）
VITE_API_BASE_URL=http://localhost:8000

# 是否启用密码强度检查（true/false）
VITE_PASSWORD_STRENGTH_CHECK=false
